{
  "id": "flaken/welcome",
  "name": "Welcome System",
  "version": "1.0.0",
  "description": "Automatic welcome messages and role assignment for new members",
  "author": "Flaken",
  "license": "MIT",
  "language": "python",
  "framework": "discord.py",
  "min_framework_version": "2.0.0",
  "command_style": "hybrid",
  "entry": "cog.py",
  "exports": ["WelcomeSystem"],
  "dependencies": {
    "pip": [],
    "flakes": []
  },
  "config": {
    "properties": {
      "welcome_channel_name": {
        "type": "string",
        "default": "welcome",
        "description": "Name of the welcome channel"
      },
      "welcome_message": {
        "type": "string",
        "default": "Welcome to the server, {member}! 🎉",
        "description": "Welcome message template"
      },
      "auto_role_name": {
        "type": "string",
        "default": "",
        "description": "Role name to assign on join (leave empty to disable)"
      }
    }
  },
  "tags": ["welcome", "greetings", "auto-role", "discord"],
  "created_at": "2026-07-15T00:00:00Z",
  "updated_at": "2026-07-15T00:00:00Z"
}
